<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SpendWise" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorPrimary">@color/electric_blue</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>
</resources>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar" tools:ignore="ThemeParent">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/electric_blue</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/neon_violet</item>
        <item name="colorSecondaryVariant">@color/bg_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/rating_poor</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialCardViewStyle">@style/Widget.MaterialComponents.CardView</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:colorControlActivated">@color/electric_blue</item>
    </style>
</resources>